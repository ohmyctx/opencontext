{
  "manifest_version": 3,
  "name": "OpenContext Browser Collector",
  "version": "0.1.0",
  "description": "Collects browser activity and sends OpenContext events to the local daemon.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["http://127.0.0.1:6060/*", "http://localhost:6060/*"],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "OpenContext Browser Collector",
    "default_popup": "popup.html"
  }
}
